{
  "_description": "50张liver肿瘤CT — small(20张) + medium(20张) + large(10张)，用于扩充分割训练数据",

  "tasks": [
    {"organ": "liver", "size_category": "small",  "phase": "early",   "output": "both", "repeat": 20},
    {"organ": "liver", "size_category": "medium", "phase": "noearly", "output": "both", "repeat": 20},
    {"organ": "liver", "size_category": "large",  "phase": "noearly", "output": "both", "repeat": 10}
  ],

  "maisi": {
    "generate_version": "rflow-ct",
    "output_size": [256, 256, 128],
    "spacing": [1.7, 1.7, 2.0],
    "num_output_samples": 1,
    "random_seed": null
  },

  "global": {
    "device": "cuda"
  }
}
